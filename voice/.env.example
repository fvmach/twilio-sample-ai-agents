# ── Twilio ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Sync Service SID — stores per-user data (account, investments, etc.)
# Find in console.twilio.com → Sync → Services
SYNC_SERVICE_SID=ISxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Handover tool endpoints ────────────────────────────────
# Twilio Function URLs for studio_handover and flex_handover tools
# Leave blank to disable these tools
STUDIO_HANDOVER_URL=https://your-functions-domain.twil.io/tools/studio-handover
FLEX_HANDOVER_URL=https://your-functions-domain.twil.io/tools/flex-handover

# ── ngrok ─────────────────────────────────────────────────
# Your custom ngrok domain (no protocol prefix)
NGROK_DOMAIN=your-domain.ngrok.io
# Required if using @ngrok/ngrok SDK (get from dashboard.ngrok.com)
NGROK_AUTHTOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override model (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# ── Segment (optional) ────────────────────────────────────
# Space ID from app.segment.com → Settings → API Keys
SEGMENT_SPACE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Access token with Profiles API read permission
SEGMENT_ACCESS_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Alpha Vantage (stocks) ────────────────────────────────
# Free key at alphavantage.co — required for get_stocks_data tool
ALPHA_VANTAGE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: Twelve Data fallback if Alpha Vantage rate-limits
# Free key at twelvedata.com
TWELVE_DATA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Server ────────────────────────────────────────────────
# Optional: override port (default: 8080)
PORT=8080
